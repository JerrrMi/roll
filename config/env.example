# 切勿将含有真实 Secret 的文件提交到 Git。
#
# 推荐：复制示例密钥文件并填入 Testnet / 实盘占位符替换为真实值：
#   cp config/secrets/testnet.env.example config/secrets/testnet.env
#   cp config/secrets/live.env.example config/secrets/live.env
#
# 在 settings.yaml 中配置 secrets.file，或在命令行使用 --secrets-file：
#   python -m main reconcile-state --secrets-file config/secrets/testnet.env
#
# 兼容 fallback（优先级最低）：在当前终端导出环境变量：
#
#   PowerShell:
#     conda activate roll-env
#     $env:BINANCE_API_KEY="your_testnet_api_key_here"
#     $env:BINANCE_API_SECRET="your_testnet_api_secret_here"
#
#   Bash:
#     conda activate roll-env
#     export BINANCE_API_KEY="your_testnet_api_key_here"
#     export BINANCE_API_SECRET="your_testnet_api_secret_here"

BINANCE_API_KEY=your_api_key_placeholder
BINANCE_API_SECRET=your_api_secret_placeholder
