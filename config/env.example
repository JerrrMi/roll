# 切勿将含有真实 Secret 的 .env 提交到 Git。
# 当前入口从进程环境变量读取（见 main / signed 命令）；可在终端中设置：
#
#   PowerShell:
#     conda activate roll-env
#     $env:BINANCE_API_KEY="..."
#     $env:BINANCE_API_SECRET="..."
#
#   Bash:
#     conda activate roll-env
#     export BINANCE_API_KEY="..."
#     export BINANCE_API_SECRET="..."

BINANCE_API_KEY=
BINANCE_API_SECRET=
